{
  "name": "@codenameryuu/adonis-lucid-soft-deletes",
  "description": "Addon for soft deletes Adonis JS with Lucid ORM",
  "version": "1.6.0",
  "author": "codenameryuu",
  "license": "MIT",
  "homepage": "https://github.com/codenameryuu/adonis-lucid-soft-deletes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenameryuu/adonis-lucid-soft-deletes.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types/*": "./build/src/types/*.js",
    "./bindings": "./build/src/bindings/model_query_builder.js",
    "./provider": "./build/providers/lucid_soft_deletes_provider.js"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "del-cli build",
    "precompile": "npm run lint && npm run clean",
    "compile": "tsc",
    "build": "npm run compile",
    "quick:test": "NODE_DEBUG=\"adonis-lucid-soft-deletes\" node --enable-source-maps --loader=ts-node/esm bin/test.ts",
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "typecheck": "tsc --noEmit",
    "version": "npm run build",
    "prepublishOnly": "npm run build",
    "release": "np"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.7.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@japa/snapshot": "^2.0.5",
    "@swc/core": "^1.6.7",
    "@types/lodash": "^4.17.6",
    "@types/luxon": "^3.4.2",
    "@types/node": "^25.5.0",
    "c8": "^9.1.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^5.1.0",
    "eslint": "^10.0.2",
    "knex": "^3.1.0",
    "lodash": "^4.17.23",
    "luxon": "^3.4.4",
    "np": "^11.0.2",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "youch": "^4.1.0"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0"
  },
  "keywords": [
    "adonisjs",
    "adonisjs-lucid",
    "adonisjs-lucid-soft-deletes",
    "adonisjs-soft-deletes",
    "adonis",
    "adonis-lucid",
    "adonis-lucid-soft-deletes",
    "adonis-soft-deletes"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "prettier": "@adonisjs/prettier-config",
  "np": {
    "message": "chore(release): %s",
    "tag": "latest",
    "branch": "main",
    "anyBranch": false
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**",
      "bin/**"
    ]
  }
}
